@{
    ViewData["Title"] = "Reportes sensibles 2";
}

<div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-4 mb-8">
        <a href="/Home/Dashboard" class="text-red-600 hover:underline">← Volver al Panel</a>
        <h1 class="text-3xl font-bold text-slate-800">🚨 Reportes: sensibles</h1>
    </div>

    <div class="bg-red-950 text-white p-6 rounded-xl mb-6 shadow-2xl border-b-4 border-red-600">
        <div class="flex items-center gap-3">
            <div class="animate-ping w-3 h-3 bg-white rounded-full"></div>
            <h2 class="font-bold uppercase tracking-widest text-sm text-red-200">Protocolo de Grabación</h2>
        </div>
        <p class="mt-2 text-red-100 italic">Área de extrema confidencialidad. Grabación RUM obligatoria.</p>
    </div>

    <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
        <h3 class="text-xl font-bold mb-4 text-slate-700">Bitácora de Operativos</h3>
        <ul class="space-y-4">
            <li class="p-4 bg-slate-50 rounded-lg border-l-4 border-red-500">
                <span class="text-xs font-bold text-slate-400">OPERATIVO #TX-90</span>
                <p class="font-semibold text-slate-800">Intervención en zona norte - Sector 4</p>
            </li>
            <li class="p-4 bg-slate-50 rounded-lg border-l-4 border-red-500">
                <span class="text-xs font-bold text-slate-400">OPERATIVO #TX-91</span>
                <p class="font-semibold text-slate-800">Seguimiento de red logística clandestina</p>
            </li>
        </ul>
    </div>
    <div class="bg-white p-8 rounded-2xl shadow-sm border border-red-200 mt-6">
    <h3 class="text-xl font-bold mb-6 text-red-800 flex items-center gap-2">
        <span>👤</span> Registro de Informante (Confidencial)
    </h3>
    <form class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-slate-600">Alias del Sujeto</label>
                <input type="text" placeholder="Nombre clave" class="w-full p-2 border border-red-100 rounded-lg focus:ring-2 focus:ring-red-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-600">Ubicación del Operativo</label>
                <input type="text" placeholder="Coordenadas o dirección" class="w-full p-2 border border-red-100 rounded-lg focus:ring-2 focus:ring-red-500 outline-none">
            </div>
        </div>
        <div>
            <label class="block text-sm font-medium text-slate-600">Número de Cuenta para Pago de Recompensa</label>
            <input type="text" placeholder="0000-0000-0000-0000" class="w-full p-2 border border-red-100 rounded-lg focus:ring-2 focus:ring-red-500 outline-none">
        </div>
        <div class="p-3 bg-red-50 rounded-lg border border-red-100">
            <p class="text-xs text-red-600">**ADVERTENCIA:** Al escribir en este formulario, se activa el rastreo de auditoría forense en tiempo real.</p>
        </div>
        <button type="button" class="w-full bg-red-700 text-white py-2 rounded-lg font-bold hover:bg-red-800 transition shadow-lg shadow-red-200">
            Transmitir Datos al Cuartel
        </button>
    </form>
</div>
</div>